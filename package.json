{
  "name": "@xcvzmoon/kickstart-typescript",
  "version": "0.0.0",
  "description": "My kickstarter for using Typescript with TSGO",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "kickstart",
    "ts7",
    "tsgo",
    "typescript"
  ],
  "author": {
    "name": "Mon Albert Gamil",
    "email": "mrgamilmonalbert@gmail.com",
    "url": "https://github.com/xcvzmoon/"
  },
  "scripts": {
    "fmt": "oxfmt && oxfmt --check",
    "lint": "oxlint",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsgo --noEmit",
    "build": "tsdown",
    "build:type": "tsc --emitDeclarationOnly --declaration --emitDeclarationOnly"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260421.2",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.21.1",
    "tsdown": "^0.21.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.33.0"
}
